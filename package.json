{
  "name": "tactic-master",
  "version": "0.1.0",
  "type": "module",
  "description": "Tactic Master - jeu de stratégie façon dames/foot, moteur de jeu + UI web",
  "scripts": {
    "build": "node tools/build.mjs",
    "test": "node tests/run-tests.js",
    "serve": "node tools/static-server.mjs public 8080",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "coverage": "c8 node tests/run-tests.js",
    "integration": "node tests/integration/run-integration.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@supabase/supabase-js": "^2.110.1",
    "c8": "^10.1.3",
    "esbuild": "^0.28.1"
  },
  "c8": {
    "include": [
      "public/src/**/*.js"
    ],
    "exclude": [
      "**/*.test.js",
      "tests/**",
      "public/vendor/**",
      "tools/**"
    ],
    "reporter": [
      "text-summary",
      "lcov"
    ],
    "check-coverage": true,
    "lines": 60,
    "statements": 60,
    "functions": 55,
    "branches": 80
  }
}
